### Node template
# Logs
logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed

# Directories for temp files
tmp/

# Generated artifacts (benchmark results, etc.)
var/

# TypeScript build output (compiled from src/ by `npm run build`)
dist/
*.tsbuildinfo

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# Coverage directory used by tools like nyc
/.nyc_output/


# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directory
# https://docs.npmjs.com/misc/faq#should-i-check-my-node-modules-folder-into-git
node_modules

# JetBrains WebStorm
.idea
.vscode

*~
.DS_Store

/examples/temp/

# Local env (secrets — never commit). .env.example is the committed contract.
.env

# Local-only working docs / AI-assistant scratch — kept on disk, not tracked.
.claude/
CLAUDE.md
# planning/ is local-only EXCEPT compatibility.md (the canonical compat matrix,
# linked from README/docs and guarded by test/meta/manifest.js).
planning/*
!planning/compatibility.md
