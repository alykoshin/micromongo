# Copy to `.env` (gitignored) and fill in.
# Real MongoDB used ONLY by the opt-in differential conformance harness
# (`npm run test:mongo`). Point it at a THROWAWAY/test database — the harness
# creates and drops temp `mmdiff_*` collections. Leave empty (or omit the file)
# to skip those tests. Any source works: docker
# (`docker run --rm -d -p 27017:27017 mongo`), a local install, or Atlas.
TEST_MONGODB_URI="<mongodb://localhost:27017 or mongodb+srv://... — a THROWAWAY db>"

# Optional: database to create the temp collections in. Defaults to the db in the
# URI path, else `mm_differential`. Set this when your account is scoped to a
# specific db (can't create arbitrary ones) — e.g. a shared test cluster.
TEST_MONGODB_DB="<optional — e.g. mytest_db>"
